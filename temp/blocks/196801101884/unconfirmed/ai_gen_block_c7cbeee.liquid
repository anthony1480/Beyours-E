{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-editorial-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-magazine-editorial__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    position: relative;
  }

  .ai-magazine-editorial__feature-{{ ai_gen_id }} {
    grid-column: span 7;
    position: relative;
    overflow: hidden;
  }

  .ai-magazine-editorial__feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-editorial__feature-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-magazine-editorial__feature-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-magazine-editorial__feature-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.content_padding }}px;
    background: linear-gradient(to top, {{ block.settings.overlay_color }}, transparent);
    color: {{ block.settings.overlay_text_color }};
  }

  .ai-magazine-editorial__category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_size }}px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
    font-weight: 600;
    display: inline-block;
  }

  .ai-magazine-editorial__feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    line-height: 1.2;
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-magazine-editorial__feature-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.6;
    margin: 0 0 16px;
    opacity: 0.9;
  }

  .ai-magazine-editorial__read-more-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.link_size }}px;
    text-decoration: none;
    color: {{ block.settings.overlay_text_color }};
    font-weight: 500;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 0.3s ease;
  }

  .ai-magazine-editorial__read-more-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-magazine-editorial__sidebar-{{ ai_gen_id }} {
    grid-column: span 5;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-editorial__article-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    transition: opacity 0.3s ease;
  }

  .ai-magazine-editorial__article-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-magazine-editorial__article-image-{{ ai_gen_id }} {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    object-fit: cover;
  }

  .ai-magazine-editorial__article-placeholder-{{ ai_gen_id }} {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-editorial__article-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
  }

  .ai-magazine-editorial__article-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-magazine-editorial__article-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.small_category_size }}px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
    color: {{ block.settings.accent_color }};
    font-weight: 600;
  }

  .ai-magazine-editorial__article-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_title_size }}px;
    line-height: 1.3;
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-magazine-editorial__article-meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.meta_color }};
  }

  .ai-magazine-editorial__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-magazine-editorial__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-magazine-editorial__feature-{{ ai_gen_id }},
    .ai-magazine-editorial__sidebar-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-magazine-editorial__feature-image-{{ ai_gen_id }},
    .ai-magazine-editorial__feature-placeholder-{{ ai_gen_id }} {
      min-height: 400px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-editorial-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-magazine-editorial__feature-image-{{ ai_gen_id }},
    .ai-magazine-editorial__feature-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-magazine-editorial__feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_title_size | times: 0.7 }}px;
    }

    .ai-magazine-editorial__article-image-{{ ai_gen_id }},
    .ai-magazine-editorial__article-placeholder-{{ ai_gen_id }} {
      width: 100px;
      height: 100px;
    }

    .ai-magazine-editorial__article-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.article_title_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<magazine-editorial-{{ ai_gen_id }} class="ai-magazine-editorial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-magazine-editorial__grid-{{ ai_gen_id }}">
    <div class="ai-magazine-editorial__feature-{{ ai_gen_id }}">
      {% if block.settings.feature_image %}
        <img
          src="{{ block.settings.feature_image | image_url: width: 1200 }}"
          alt="{{ block.settings.feature_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.feature_image.width }}"
          height="{{ block.settings.feature_image.height }}"
          class="ai-magazine-editorial__feature-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-magazine-editorial__feature-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-magazine-editorial__empty-state-{{ ai_gen_id }}">
            Add a feature image
          </div>
        </div>
      {% endif %}

      <div class="ai-magazine-editorial__feature-content-{{ ai_gen_id }}">
        {% if block.settings.feature_category != blank %}
          <div class="ai-magazine-editorial__category-{{ ai_gen_id }}">
            {{ block.settings.feature_category }}
          </div>
        {% endif %}

        {% if block.settings.feature_title != blank %}
          <h2 class="ai-magazine-editorial__feature-title-{{ ai_gen_id }}">
            {{ block.settings.feature_title }}
          </h2>
        {% endif %}

        {% if block.settings.feature_excerpt != blank %}
          <div class="ai-magazine-editorial__feature-excerpt-{{ ai_gen_id }}">
            {{ block.settings.feature_excerpt }}
          </div>
        {% endif %}

        {% if block.settings.feature_link != blank %}
          <a href="{{ block.settings.feature_link }}" class="ai-magazine-editorial__read-more-{{ ai_gen_id }}">
            {{ block.settings.read_more_text }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-magazine-editorial__sidebar-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign article_image_key = 'article_' | append: i | append: '_image'
          assign article_category_key = 'article_' | append: i | append: '_category'
          assign article_title_key = 'article_' | append: i | append: '_title'
          assign article_date_key = 'article_' | append: i | append: '_date'
          assign article_link_key = 'article_' | append: i | append: '_link'

          assign article_image = block.settings[article_image_key]
          assign article_category = block.settings[article_category_key]
          assign article_title = block.settings[article_title_key]
          assign article_date = block.settings[article_date_key]
          assign article_link = block.settings[article_link_key]
        %}

        {% if article_title != blank %}
          <a href="{{ article_link }}" class="ai-magazine-editorial__article-{{ ai_gen_id }}">
            {% if article_image %}
              <img
                src="{{ article_image | image_url: width: 240 }}"
                alt="{{ article_image.alt | escape }}"
                loading="lazy"
                width="120"
                height="120"
                class="ai-magazine-editorial__article-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-magazine-editorial__article-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}

            <div class="ai-magazine-editorial__article-content-{{ ai_gen_id }}">
              {% if article_category != blank %}
                <div class="ai-magazine-editorial__article-category-{{ ai_gen_id }}">
                  {{ article_category }}
                </div>
              {% endif %}

              <h3 class="ai-magazine-editorial__article-title-{{ ai_gen_id }}">
                {{ article_title }}
              </h3>

              {% if article_date != blank %}
                <div class="ai-magazine-editorial__article-meta-{{ ai_gen_id }}">
                  {{ article_date }}
                </div>
              {% endif %}
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</magazine-editorial-{{ ai_gen_id }}>

<script>
  (function() {
    class MagazineEditorial{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const links = this.querySelectorAll('a');
        links.forEach(link => {
          if (!link.getAttribute('aria-label') && link.querySelector('img')) {
            const title = link.querySelector('.ai-magazine-editorial__article-title-{{ ai_gen_id }}, .ai-magazine-editorial__feature-title-{{ ai_gen_id }}');
            if (title) {
              link.setAttribute('aria-label', title.textContent.trim());
            }
          }
        });
      }
    }

    customElements.define('magazine-editorial-{{ ai_gen_id }}', MagazineEditorial{{ ai_gen_id }});
  })();
</script>

