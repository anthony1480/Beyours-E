{% doc %}
  @prompt
    video on the left of the page with text on the right  
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-video-text-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    max-width: {{ block.settings.page_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-text-video-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.video_width }}%;
    position: relative;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
  }

  .ai-video-text-video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-video-text-video-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-text-video-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-video-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-text-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-video-text-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-video-text-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-video-text-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-video-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-video-text-container-{{ ai_gen_id }} {
      flex-direction: column;
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-video-text-video-wrapper-{{ ai_gen_id }} {
      flex: 0 0 100%;
      width: 100%;
    }

    .ai-video-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-video-text-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }
  }
{% endstyle %}

<video-text-{{ ai_gen_id }} class="ai-video-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-text-container-{{ ai_gen_id }}">
    <div class="ai-video-text-video-wrapper-{{ ai_gen_id }}">
      {% if block.settings.video %}
        <video
          class="ai-video-text-video-{{ ai_gen_id }}"
          {% if block.settings.autoplay %}autoplay{% endif %}
          {% if block.settings.loop %}loop{% endif %}
          {% if block.settings.muted %}muted{% endif %}
          {% if block.settings.controls %}controls{% endif %}
          playsinline
        >
          <source src="{{ block.settings.video }}" type="video/mp4">
        </video>
      {% else %}
        <div class="ai-video-text-video-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-video-text-empty-state-{{ ai_gen_id }}">
            Next, add a video
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-video-text-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-video-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-video-text-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.button_label != blank and block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-video-text-button-{{ ai_gen_id }}">
          {{ block.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</video-text-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoText{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const video = this.querySelector('.ai-video-text-video-{{ ai_gen_id }}');
        if (video && video.hasAttribute('autoplay')) {
          video.play().catch(function() {});
        }
      }
    }

    customElements.define('video-text-{{ ai_gen_id }}', VideoText{{ ai_gen_id }});
  })();
</script>

