<script>
  (function() {
    class SkinConcernQuiz{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentQuestion = 1;
        this.totalQuestions = 4;
        this.answers = {};
        this.concernMapping = {
          '{{ block.settings.concern1_value }}': {
            name: '{{ block.settings.concern1_name }}',
            description: '{{ block.settings.concern1_description }}',
            products: {{ block.settings.concern1_products | json }}
          },
          '{{ block.settings.concern2_value }}': {
            name: '{{ block.settings.concern2_name }}',
            description: '{{ block.settings.concern2_description }}',
            products: {{ block.settings.concern2_products | json }}
          },
          '{{ block.settings.concern3_value }}': {
            name: '{{ block.settings.concern3_name }}',
            description: '{{ block.settings.concern3_description }}',
            products: {{ block.settings.concern3_products | json }}
          },
          '{{ block.settings.concern4_value }}': {
            name: '{{ block.settings.concern4_name }}',
            description: '{{ block.settings.concern4_description }}',
            products: {{ block.settings.concern4_products | json }}
          },
          '{{ block.settings.concern5_value }}': {
            name: '{{ block.settings.concern5_name }}',
            description: '{{ block.settings.concern5_description }}',
            products: {{ block.settings.concern5_products | json }}
          }
        };
      }

      connectedCallback() {
        this.progressBar = this.querySelector('[data-progress]');
        this.backButton = this.querySelector('[data-back]');
        this.nextButton = this.querySelector('[data-next]');
        this.resultsSection = this.querySelector('[data-results]');
        this.questionsSection = this.querySelector('[data-questions]');
        this.restartButton = this.querySelector('[data-restart]');

        this.setupEventListeners();
        this.updateProgress();
      }

      setupEventListeners() {
        const options = this.querySelectorAll('.ai-skin-quiz__option-{{ ai_gen_id }}');
        options.forEach(option => {
          option.addEventListener('click', () => this.selectOption(option));
        });

        this.backButton.addEventListener('click', () => this.goBack());
        this.nextButton.addEventListener('click', () => this.goNext());
        this.restartButton.addEventListener('click', () => this.restart());
      }

      selectOption(option) {
        const questionNum = option.dataset.question;
        const value = option.dataset.value;

        const siblings = this.querySelectorAll(`[data-question="${questionNum}"].ai-skin-quiz__option-{{ ai_gen_id }}`);
        siblings.forEach(sib => sib.classList.remove('selected'));

        option.classList.add('selected');
        this.answers[questionNum] = value;

        this.nextButton.disabled = false;
      }

      goBack() {
        if (this.currentQuestion > 1) {
          this.currentQuestion--;
          this.updateQuestionDisplay();
          this.updateProgress();
          this.updateButtons();
        }
      }

      goNext() {
        if (this.currentQuestion < this.totalQuestions) {
          this.currentQuestion++;
          this.updateQuestionDisplay();
          this.updateProgress();
          this.updateButtons();
        } else {
          this.showResults();
        }
      }

      updateQuestionDisplay() {
        const questions = this.querySelectorAll('.ai-skin-quiz__question-{{ ai_gen_id }}');
        questions.forEach((q, index) => {
          if (index + 1 === this.currentQuestion) {
            q.classList.add('active');
          } else {
            q.classList.remove('active');
          }
        });
      }

      updateProgress() {
        const progress = (this.currentQuestion / this.totalQuestions) * 100;
        this.progressBar.style.width = progress + '%';
      }

      updateButtons() {
        this.backButton.disabled = this.currentQuestion === 1;

        const currentAnswer = this.answers[this.currentQuestion];
        this.nextButton.disabled = !currentAnswer;

        if (this.currentQuestion === this.totalQuestions) {
          this.nextButton.textContent = 'See Results';
        } else {
          this.nextButton.textContent = 'Next';
        }
      }

      determineConcern() {
        const logic = '{{ block.settings.concern_logic }}';
        
        if (logic === 'q1') {
          return this.answers['1'] || '{{ block.settings.concern1_value }}';
        } else if (logic === 'q2') {
          return this.answers['2'] || '{{ block.settings.concern1_value }}';
        } else if (logic === 'q3') {
          return this.answers['3'] || '{{ block.settings.concern1_value }}';
        } else if (logic === 'q4') {
          return this.answers['4'] || '{{ block.settings.concern1_value }}';
        }
        
        return '{{ block.settings.concern1_value }}';
      }

      showResults() {
        const concern = this.determineConcern();
        const concernData = this.concernMapping[concern];

        if (concernData && concernData.name) {
          this.querySelector('[data-concern-name]').textContent = concernData.name;
          this.querySelector('[data-concern-description]').textContent = concernData.description;
          this.renderProducts(concernData.products);
        } else {
          this.querySelector('[data-concern-name]').textContent = 'Your Results';
          this.querySelector('[data-concern-description]').textContent = 'Thank you for completing the quiz!';
          this.renderProducts([]);
        }

        this.questionsSection.style.display = 'none';
        this.querySelector('.ai-skin-quiz__navigation-{{ ai_gen_id }}').style.display = 'none';
        this.querySelector('.ai-skin-quiz__progress-{{ ai_gen_id }}').style.display = 'none';
        this.resultsSection.classList.add('active');
      }

      renderProducts(productHandles) {
        const productsContainer = this.querySelector('[data-products]');
        productsContainer.innerHTML = '';

        if (!productHandles || productHandles.length === 0) {
          productsContainer.innerHTML = '<p style="grid-column: 1/-1; text-align: center;">No products available for this concern yet.</p>';
          return;
        }

        productHandles.forEach(handle => {
          fetch(`/products/${handle}.js`)
            .then(response => response.json())
            .then(product => {
              const productCard = this.createProductCard(product);
              productsContainer.appendChild(productCard);
            })
            .catch(error => {
              console.error('Error fetching product:', error);
            });
        });
      }

      createProductCard(product) {
        const card = document.createElement('a');
        card.href = `/products/${product.handle}`;
        card.className = 'ai-skin-quiz__product-{{ ai_gen_id }}';

        const imageHtml = product.featured_image
          ? `<img src="${product.featured_image}" alt="${product.title}" class="ai-skin-quiz__product-image-{{ ai_gen_id }}" loading="lazy">`
          : `<div class="ai-skin-quiz__product-placeholder-{{ ai_gen_id }}">${'{{ "image" | placeholder_svg_tag }}'}</div>`;

        const price = (product.price / 100).toFixed(2);

        card.innerHTML = `
          ${imageHtml}
          <h3 class="ai-skin-quiz__product-title-{{ ai_gen_id }}">${product.title}</h3>
          <div class="ai-skin-quiz__product-price-{{ ai_gen_id }}">$${price}</div>
          <span class="ai-skin-quiz__product-button-{{ ai_gen_id }}">View Product</span>
        `;

        return card;
      }

      restart() {
        this.currentQuestion = 1;
        this.answers = {};

        const options = this.querySelectorAll('.ai-skin-quiz__option-{{ ai_gen_id }}');
        options.forEach(option => option.classList.remove('selected'));

        this.questionsSection.style.display = 'block';
        this.querySelector('.ai-skin-quiz__navigation-{{ ai_gen_id }}').style.display = 'flex';
        this.querySelector('.ai-skin-quiz__progress-{{ ai_gen_id }}').style.display = 'block';
        this.resultsSection.classList.remove('active');

        this.updateQuestionDisplay();
        this.updateProgress();
        this.updateButtons();
      }
    }

    customElements.define('skin-concern-quiz-{{ ai_gen_id }}', SkinConcernQuiz{{ ai_gen_id }});
  })();
</script>

