          }
        },
        "text_bLHQf9": {
          "type": "text",
          "settings": {
            "text": "<p><br/>Exfoliate first to clear buildup, smooth rough skin, and release trapped hairs.<br/><br/>Shave with our protective gel that creates a barrier between your skin and the razor, minimizing irritation, nicks, and cuts.<br/><br/>Finish with the aftershave oil to soothe, deeply moisturize, and help prevent ingrown hairs, itching, and bumps.<br/><br/></p>",
